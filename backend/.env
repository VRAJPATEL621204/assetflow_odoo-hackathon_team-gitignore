# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://cde:cde_secret@localhost:5439/company_discovery?schema=public"

# Security (JWT)
JWT_SECRET="your_jwt_super_secret_key_at_least_32_chars"
JWT_EXPIRES_IN="7d"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100 # limit each IP to 100 requests per windowMs
