datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. users Table
model User {
  id           Int      @id @default(autoincrement()) @map("id")
  email        String   @unique @map("email")
  passwordHash String   @map("password_hash")
  name         String   @map("name")
  status       String   @default("ACTIVE") @map("status") // ACTIVE, INACTIVE
  departmentId Int?     @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department          Department?          @relation(fields: [departmentId], references: [id])
  userRoles           UserRole[]
  allocations         AssetAllocation[]
  raisedTransfers     TransferRequest[]    @relation("RequestedByUser")
  approvedTransfers   TransferRequest[]    @relation("ApprovedByUser")
  bookings            ResourceBooking[]
  maintenanceRequests MaintenanceRequest[] @relation("RaisedByUser")
  approvedMaintenance MaintenanceRequest[] @relation("ApprovedByUser")
  auditedCycles       AuditAssignment[]
  verifications       AuditVerification[]
  activityLogs        ActivityLog[]
  notifications       SystemNotification[]

  @@map("users")
}

// 2. roles Table
model Role {
  id          Int      @id @default(autoincrement()) @map("id")
  name        String   @unique @map("name") // ADMIN, ASSET_MANAGER, DEPT_HEAD, EMPLOYEE
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

// 3. permissions Table
model Permission {
  id          Int      @id @default(autoincrement()) @map("id")
  name        String   @unique @map("name") // e.g. "create_asset", "approve_transfer"
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

// 4. user_roles Join Table (M:N)
model UserRole {
  id        Int      @id @default(autoincrement()) @map("id")
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// 5. role_permissions Join Table (M:N)
model RolePermission {
  id           Int      @id @default(autoincrement()) @map("id")
  roleId       Int      @map("role_id")
  permissionId Int      @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// 6. departments Table
model Department {
  id               Int      @id @default(autoincrement()) @map("id")
  name             String   @map("name")
  parentId         Int?     @map("parent_id")
  status           String   @default("ACTIVE") @map("status") // ACTIVE, INACTIVE
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  parent           Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  subDepartments   Department[]      @relation("DepartmentHierarchy")
  employees        User[]
  assets           Asset[]
  assetAllocations AssetAllocation[]

  @@map("departments")
}

// 7. locations Table
model Location {
  id        Int      @id @default(autoincrement()) @map("id")
  name      String   @map("name") // e.g. "Main Office", "Warehouse A"
  address   String?  @map("address")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assets Asset[]

  @@map("locations")
}

// 8. asset_categories Table
model AssetCategory {
  id        Int      @id @default(autoincrement()) @map("id")
  name      String   @unique @map("name") // e.g. Electronics, Furniture, Vehicles
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customFields AssetCustomField[]
  assets       Asset[]

  @@map("asset_categories")
}

// 9. asset_custom_fields Table (For category-specific dynamic schemas)
model AssetCustomField {
  id          Int      @id @default(autoincrement()) @map("id")
  categoryId  Int      @map("category_id")
  fieldName   String   @map("field_name") // e.g. "warranty_period"
  fieldType   String   @map("field_type") // e.g. "number", "string", "boolean"
  isRequired  Boolean  @default(false) @map("is_required")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category         AssetCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assetFieldValues AssetFieldValue[]

  @@unique([categoryId, fieldName])
  @@map("asset_custom_fields")
}

// 10. assets Table
model Asset {
  id              Int      @id @default(autoincrement()) @map("id")
  tag             String   @unique @map("tag") // e.g. AF-0001
  name            String   @map("name")
  serialNumber    String?  @map("serial_number")
  acquisitionDate DateTime @map("acquisition_date")
  acquisitionCost Decimal  @db.Decimal(12, 2) @map("acquisition_cost")
  condition       String   @map("condition") // NEW, GOOD, FAIR, POOR
  locationId      Int?     @map("location_id")
  status          String   @default("AVAILABLE") @map("status") // AVAILABLE, ALLOCATED, RESERVED, UNDER_MAINTENANCE, LOST, RETIRED, DISPOSED
  isShared        Boolean  @default(false) @map("is_shared") // Shared/Bookable resource flag
  photoUrl        String?  @map("photo_url")
  categoryId      Int      @map("category_id")
  departmentId    Int?     @map("department_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  category            AssetCategory         @relation(fields: [categoryId], references: [id])
  location            Location?             @relation(fields: [locationId], references: [id])
  department          Department?           @relation(fields: [departmentId], references: [id])
  fieldValues         AssetFieldValue[]
  components          AssetComponent[]
  documents           AssetDocument[]
  allocations         AssetAllocation[]
  maintenanceRequests MaintenanceRequest[]
  verifications       AuditVerification[]
  discrepancies       AuditDiscrepancy[]

  @@map("assets")
}

// 11. asset_field_values Table (Join table containing actual values for custom fields)
model AssetFieldValue {
  id            Int      @id @default(autoincrement()) @map("id")
  assetId       Int      @map("asset_id")
  customFieldId Int      @map("custom_field_id")
  value         String   @map("value") // Stored as string, parsed based on fieldType
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  asset       Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  customField AssetCustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([assetId, customFieldId])
  @@map("asset_field_values")
}

// 12. asset_components Table (Accessories/Sub-assets attached to a parent asset)
model AssetComponent {
  id           Int      @id @default(autoincrement()) @map("id")
  parentId     Int      @map("parent_id")
  name         String   @map("name") // e.g. "16GB RAM module", "GPU"
  serialNumber String?  @map("serial_number")
  addedDate    DateTime @default(now()) @map("added_date")
  status       String   @default("ACTIVE") @map("status") // ACTIVE, REMOVED

  parent Asset @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@map("asset_components")
}

// 13. asset_documents Table (Attachments linked to assets)
model AssetDocument {
  id         Int      @id @default(autoincrement()) @map("id")
  assetId    Int      @map("asset_id")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  fileType   String   @map("file_type") // invoice, manual, image, warranty_doc
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("asset_documents")
}

// 14. asset_allocations Table
model AssetAllocation {
  id                 Int       @id @default(autoincrement()) @map("id")
  assetId            Int       @map("asset_id")
  employeeId         Int?      @map("employee_id")
  departmentId       Int?      @map("department_id")
  allocatedDate      DateTime  @default(now()) @map("allocated_date")
  expectedReturnDate DateTime? @map("expected_return_date")
  actualReturnDate   DateTime? @map("actual_return_date")
  returnCondition    String?   @map("return_condition")
  checkInNotes       String?   @map("check_in_notes")
  status             String    @default("ACTIVE") @map("status") // ACTIVE, RETURNED, TRANSFERRED
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  asset            Asset               @relation(fields: [assetId], references: [id])
  employee         User?               @relation(fields: [employeeId], references: [id])
  department       Department?         @relation(fields: [departmentId], references: [id])
  transferRequests TransferRequest[]
  allocationHistory AllocationHistory[]

  @@map("asset_allocations")
}

// 15. transfer_requests Table
model TransferRequest {
  id                 Int      @id @default(autoincrement()) @map("id")
  allocationId       Int      @map("allocation_id")
  requestedById      Int      @map("requested_by_id")
  targetEmployeeId   Int?     @map("target_employee_id")
  targetDepartmentId Int?     @map("target_department_id")
  reason             String   @map("reason")
  status             String   @default("PENDING") @map("status") // PENDING, APPROVED, REJECTED
  approvedById       Int?     @map("approved_by_id")
  actionedAt         DateTime? @map("actioned_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  allocation       AssetAllocation @relation(fields: [allocationId], references: [id])
  requestedByUser  User            @relation("RequestedByUser", fields: [requestedById], references: [id])
  approvedByUser   User?           @relation("ApprovedByUser", fields: [approvedById], references: [id])

  @@map("transfer_requests")
}

// 16. allocation_history Table (Timeline log)
model AllocationHistory {
  id                Int      @id @default(autoincrement()) @map("id")
  assetAllocationId Int      @map("asset_allocation_id")
  action            String   @map("action") // CREATE, RETURN, TRANSFER, OVERDUE
  details           String?  @map("details")
  createdAt         DateTime @default(now()) @map("created_at")

  allocation AssetAllocation @relation(fields: [assetAllocationId], references: [id], onDelete: Cascade)

  @@map("allocation_history")
}

// 17. resources Table (Bookable locations/shared amenities)
model Resource {
  id          Int      @id @default(autoincrement()) @map("id")
  name        String   @map("name") // e.g. "Conference Room A", "Pool Car"
  type        String   @map("type") // ROOM, VEHICLE, EQUIPMENT
  description String?  @map("description")
  status      String   @default("ACTIVE") @map("status") // ACTIVE, INACTIVE
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bookings       ResourceBooking[]
  availabilities ResourceAvailability[]

  @@map("resources")
}

// 18. resource_availabilities Table
model ResourceAvailability {
  id         Int      @id @default(autoincrement()) @map("id")
  resourceId Int      @map("resource_id")
  dayOfWeek  Int      @map("day_of_week") // 0 (Sunday) to 6 (Saturday)
  startTime  String   @map("class_start_time") // e.g. "09:00"
  endTime    String   @map("class_end_time") // e.g. "17:00"

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@map("resource_availabilities")
}

// 19. resource_bookings Table
model ResourceBooking {
  id         Int      @id @default(autoincrement()) @map("id")
  resourceId Int      @map("resource_id")
  bookedById Int      @map("booked_by_id")
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")
  status     String   @default("UPCOMING") @map("status") // UPCOMING, ONGOING, COMPLETED, CANCELLED
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  resource Resource @relation(fields: [resourceId], references: [id])
  bookedBy User     @relation(fields: [bookedById], references: [id])

  @@map("resource_bookings")
}

// 20. technicians Table (Internal/External maintainers)
model Technician {
  id           Int      @id @default(autoincrement()) @map("id")
  name         String   @map("name")
  email        String   @unique @map("email")
  phone        String?  @map("phone")
  specialty    String?  @map("specialty") // e.g. IT, Electrical, Mechanical
  status       String   @default("ACTIVE") @map("status") // ACTIVE, INACTIVE
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  maintenanceRequests MaintenanceRequest[]

  @@map("technicians")
}

// 21. maintenance_requests Table
model MaintenanceRequest {
  id           Int      @id @default(autoincrement()) @map("id")
  assetId      Int      @map("asset_id")
  raisedById   Int      @map("raised_by_id")
  description  String   @map("description")
  priority     String   @map("priority") // LOW, MEDIUM, HIGH, CRITICAL
  status       String   @default("PENDING") @map("status") // PENDING, APPROVED, REJECTED, IN_PROGRESS, RESOLVED
  photoUrl     String?  @map("photo_url")
  approvedById Int?     @map("approved_by_id")
  technicianId Int?     @map("technician_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  asset            Asset            @relation(fields: [assetId], references: [id])
  raisedByUser     User             @relation("RaisedByUser", fields: [raisedById], references: [id])
  approvedByUser   User?            @relation("ApprovedByUser", fields: [approvedById], references: [id])
  technician       Technician?      @relation(fields: [technicianId], references: [id])
  maintenanceLogs  MaintenanceLog[]

  @@map("maintenance_requests")
}

// 22. maintenance_logs Table (Work action records)
model MaintenanceLog {
  id                   Int      @id @default(autoincrement()) @map("id")
  maintenanceRequestId Int      @map("maintenance_request_id")
  actionTaken          String   @map("action_taken")
  partsReplaced        String?  @map("parts_replaced")
  cost                 Decimal  @default(0.00) @db.Decimal(10, 2) @map("cost")
  loggedDate           DateTime @default(now()) @map("logged_date")

  request MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)

  @@map("maintenance_logs")
}

// 23. audit_cycles Table
model AuditCycle {
  id           Int      @id @default(autoincrement()) @map("id")
  name         String   @map("name") // e.g. "Q3 Electronics Audit"
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  status       String   @default("SCHEDULED") @map("status") // SCHEDULED, ACTIVE, CLOSED
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditors      AuditAssignment[]
  verifications AuditVerification[]
  discrepancies AuditDiscrepancy[]

  @@map("audit_cycles")
}

// 24. audit_assignments Table (Join table for cycle auditors M:N)
model AuditAssignment {
  id           Int      @id @default(autoincrement()) @map("id")
  auditCycleId Int      @map("audit_cycle_id")
  auditorId    Int      @map("auditor_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  auditor    User       @relation(fields: [auditorId], references: [id], onDelete: Cascade)

  @@unique([auditCycleId, auditorId])
  @@map("audit_assignments")
}

// 25. audit_verifications Table (Individual checks)
model AuditVerification {
  id               Int      @id @default(autoincrement()) @map("id")
  auditCycleId     Int      @map("audit_cycle_id")
  assetId          Int      @map("asset_id")
  auditorId        Int      @map("auditor_id")
  status           String   @map("status") // VERIFIED, MISSING, DAMAGED
  verificationDate DateTime @default(now()) @map("verification_date")
  notes            String?  @map("notes")

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id])
  auditor    User       @relation(fields: [auditorId], references: [id])

  @@unique([auditCycleId, assetId])
  @@map("audit_verifications")
}

// 26. audit_discrepancies Table (Auto-generated items from verifications)
model AuditDiscrepancy {
  id           Int      @id @default(autoincrement()) @map("id")
  auditCycleId Int      @map("audit_cycle_id")
  assetId      Int      @map("asset_id")
  issueType    String   @map("issue_type") // MISSING, DAMAGED
  resolved     Boolean  @default(false) @map("resolved")
  resolvedAt   DateTime? @map("resolved_at")
  notes        String?  @map("notes")
  createdAt    DateTime @default(now()) @map("created_at")

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([auditCycleId, assetId])
  @@map("audit_discrepancies")
}

// 27. activity_logs Table (Admin audit trail)
model ActivityLog {
  id         Int      @id @default(autoincrement()) @map("id")
  userId     Int      @map("user_id")
  action     String   @map("action") // e.g. "USER_LOGIN", "ASSET_CREATE"
  entityName String   @map("entity_name") // e.g. "asset", "user"
  entityId   Int?     @map("entity_id")
  details    String?  @map("details")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// 28. system_notifications Table
model SystemNotification {
  id        Int      @id @default(autoincrement()) @map("id")
  userId    Int      @map("user_id")
  type      String   @map("type") // OVERDUE, REQUEST_PENDING, BOOKING_START, GENERAL
  message   String   @map("message")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("system_notifications")
}
